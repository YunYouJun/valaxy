    "@vueuse/motion": "catalog:",
    "animejs": "catalog:",
    "gsap": "catalog:",
    "reka-ui": "catalog:frontend"
  },
  "devDependencies": {
    "@types/animejs": "catalog:",
    "valaxy": "workspace:*",
    "valaxy-addon-waline": "workspace:*"
  }
