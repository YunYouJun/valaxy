{
  "name": "create-valaxy",
  "type": "module",
  "version": "0.28.11",
  "description": "Create Starter Template for Valaxy",
  "author": {
    "email": "me@yunyoujun.cn",
    "name": "YunYouJun",
    "url": "https://www.yunyoujun.cn"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/YunYouJun",
  "homepage": "https://valaxy.site",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YunYouJun/valaxy.git",
    "directory": "packages/create-valaxy"
  },
  "keywords": [
    "valaxy",
    "create-valaxy",
    "scaffolding"
  ],
  "main": "bin/index.mjs",
  "bin": {
    "create-valaxy": "bin/index.mjs"
  },
  "files": [
    "bin",
    "dist",
    "template-*/**/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "unbuild",
    "dev": "unbuild --stub",
    "prepublishOnly": "npm run build",
    "release": "bumpp --no-commit --no-tag --no-push && pnpm publish --no-git-checks --tag beta",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "consola": "catalog:build",
    "execa": "catalog:",
    "minimist": "catalog:",
    "prompts": "catalog:"
  },
  "devDependencies": {
    "@types/minimist": "catalog:"
  }
}
